# Documentation: https://cockpit.app.minitap.ai/docs/guide/local-development/env-vars

# minitest-cli environment configuration.
# Active values target local development; Production / Development blocks are
# deployed values kept commented for reference.

# —— Testing Service ——
# Production
# MINITEST_API_URL=https://testing-service.minitap.ai
# Development
MINITEST_API_URL=https://testing-service.dev.minitap.ai

# —— Authentication ——
# Pre-authenticated token — bypasses OAuth login entirely. Useful for CI/CD.
# MINITEST_TOKEN=

# —— Default App ——
# Default app ID for commands that require --app
# MINITEST_APP_ID=

# —— Supabase OAuth ——
# Production
# MINITEST_SUPABASE_URL=https://supabase.minitap.ai
# Development
MINITEST_SUPABASE_URL=https://qrezuucghnmfvaxghqsv.supabase.co
MINITEST_SUPABASE_PUBLISHABLE_KEY=sb_publishable_4JRhoCm8pa5PbII0dhS09A_jhpkQhmy
