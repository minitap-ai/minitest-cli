# Documentation: https://cockpit.app.minitap.ai/docs/guide/local-development/env-vars

# minitest-cli environment configuration.
# Active values target local development; Production / Development blocks are
# deployed values kept commented for reference.

# —— Testing Service ——
# Production
# MINITEST_API_URL=https://testing-service.app.minitap.ai
# Development
MINITEST_API_URL=https://testing-service.dev.minitap.ai

# —— Apps Manager ——
# Production
# MINITEST_APPS_MANAGER_URL=https://apps-manager.app.minitap.ai
# Development
MINITEST_APPS_MANAGER_URL=https://apps-manager.dev.minitap.ai

# —— Integrations ——
# Production
# MINITEST_INTEGRATIONS_URL=https://integrations.minitap.ai
# Development
MINITEST_INTEGRATIONS_URL=https://integrations.dev.minitap.ai

# —— Authentication ——
# Pre-authenticated token — bypasses OAuth login entirely. Useful for CI/CD.
# MINITEST_TOKEN=

# —— Default App ——
# Default app ID for commands that require --app
# MINITEST_APP_ID=

# —— Supabase OAuth ——
# Production
# MINITEST_SUPABASE_URL=https://auth.minitap.ai
# MINITEST_SUPABASE_PUBLISHABLE_KEY=sb_publishable_HmeivoYFvddM7ud1z1DzUA_7zXZj5v7
# Development
MINITEST_SUPABASE_URL=https://qrezuucghnmfvaxghqsv.supabase.co
MINITEST_SUPABASE_PUBLISHABLE_KEY=sb_publishable_4JRhoCm8pa5PbII0dhS09A_jhpkQhmy
